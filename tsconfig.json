{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "jsx": "preserve",
        "sourceMap": true,
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "lib": ["ESNext", "DOM"],
        "types": ["vite/client"],
        "baseUrl": ".",
        "paths": {
            "@/*": ["resources/js/*"],
            "vuex": ["./node_modules/vuex/types/index.d.ts"]
        }
    },
    "include": ["resources/js/**/*"],
    "exclude": ["node_modules", "vendor"]
}
